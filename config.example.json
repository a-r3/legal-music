{
  "_comment": "legal-music config — copy to ~/.config/legal-music/config.json and edit",

  "delay": 0.25,
  "max_results": 5,
  "timeout": 10,
  "per_song_timeout": 16,

  "min_downloadable_score": 0.46,
  "min_page_score": 0.48,

  "cache_enabled": true,
  "persistent_cache_enabled": false,

  "sources": [
    {"name": "Internet Archive",   "enabled": true},
    {"name": "Free Music Archive", "enabled": true},
    {"name": "Bandcamp",           "enabled": true},
    {"name": "Jamendo",            "enabled": false},
    {"name": "Pixabay Music",      "enabled": false}
  ],

  "csv_report": true,
  "xlsx_report": true
}
