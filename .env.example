# legal-music Telegram Bot — environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram channel/chat ID where downloaded songs will be forwarded
# Use a positive integer for a user/group, or @channelusername for a public channel
# Example: -1001234567890  or  @mychannel
CHANNEL_ID=

# Save downloaded files locally on the bot's machine (default: true)
# true  → files are kept in output/bot_downloads/ after sending
# false → files are deleted after being sent to Telegram
SAVE_LOCAL=true

# Custom directory to store downloaded files (optional)
# Default: ~/.local/share/legal-music/output/bot_downloads
# DOWNLOADS_DIR=/path/to/your/music/folder
